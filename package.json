{
  "name": "cubs-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "cubs-database:build": "npm run cubs-components:build && node packages/cubs-database/scripts/build.mjs",
    "cubs-database:bump": "node packages/cubs-database/scripts/bump.mjs",
    "cubs-database:pack": "npm pack ./packages/cubs-database --pack-destination packages/cubs-database",
    "cubs-components:build": "node packages/cubs-components/scripts/build.mjs",
    "cubs-components:bump": "node packages/cubs-components/scripts/bump.mjs",
    "cubs-components:pack": "npm pack ./packages/cubs-components --pack-destination packages/cubs-components"
  },
  "dependencies": {
    "@fontsource-variable/noto-sans": "5.2.10",
    "@iconify/react": "6.0.2",
    "@radix-ui/react-checkbox": "1.3.7",
    "@radix-ui/react-dialog": "1.1.19",
    "@radix-ui/react-select": "2.3.3",
    "@tailwindcss/vite": "4.3.2",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-router": "1.170.17",
    "axios": "1.18.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cubs-components": "file:packages/cubs-components",
    "cubs-database": "file:packages/cubs-database",
    "i18next": "26.3.6",
    "lucide-react": "1.24.0",
    "polished": "4.3.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.81.0",
    "react-i18next": "17.0.9",
    "socket.io-client": "4.8.3",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.2",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/router-plugin": "1.168.19",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "oxlint": "1.73.0",
    "typescript": "6.0.3",
    "vite": "8.1.4"
  }
}
